<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="/style.css">
    <title>All Posts</title>
</head>
<body>

<div class="header">All Posts</div>

<div class="main-box">
<% for (let values of value) { %>
    <div class="box">
        <h3><%= values.name %></h3>
        <p><%= values.comment %></p>

       
        <a href="/view/<%= values.id %>/edit">
            <button class="edit-btn">Edit</button>
        </a>
<br><br>
     
        <form action="/view/<%= values.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this post?')">
            <button class="delete-btn">Delete</button>
        </form>

    </div>
<% } %>
</div>
<br>
<div class="nav-bar">
    <a href="http://localhost:8080" class="home-btn">🏠 Home</a>
</div>
</body>
</html>
